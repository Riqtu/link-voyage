# API
PORT=4000
MONGODB_URI=mongodb://localhost:27017/link-voyage
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me
# Через запятую email (строчными); при входе/register этим аккаунтам выставляется systemRole admin (для первых администраторов).
ADMIN_EMAILS=
WEB_ORIGIN=http://localhost:3000
GOOGLE_GEOCODING_API_KEY=
# Курс USD→RUB на экране жилья: ключ не нужен, данные ЦБ (cbr-xml-daily.ru).

# Google AI (карточка жилья по ссылке; разбор фото чека в разделе «Чеки», опционально)
GEMINI_API_KEY=
GEMINI_MODEL=
# JSON-ответ по жилью: лимит токенов (1024–8192). По умолчанию 4096 — ниже режет длинный previewDescription и ломает JSON.
GEMINI_ENRICH_MAX_OUTPUT_TOKENS=
# Логи обогащения жилья Gemini: off | 1/summary/true | debug (сырой ответ и поля итога, усечённо). В debug попадают URL и фрагменты текста — не включайте в проде без необходимости.
GEMINI_ENRICH_LOG=

# Превью ссылок (жильё): при LINK_PREVIEW_PLAYWRIGHT=auto слабое HTTP‑превью догружается через Chromium.
# Установка браузера из корня репо: pnpm --filter api exec playwright install chromium (опц. --with-deps на Linux CI).
# LINK_PREVIEW_PLAYWRIGHT=off | auto | force (always Chromium). Timeout и пауза после domcontentloaded (мс): LINK_PREVIEW_PLAYWRIGHT_TIMEOUT_MS, LINK_PREVIEW_PLAYWRIGHT_SETTLE_MS.
# LINK_PREVIEW_PLAYWRIGHT_SCROLL_PX — лёгкий скролл для lazy‑картинок (0 = выкл, по умолчанию ~8000px).
LINK_PREVIEW_PLAYWRIGHT=
LINK_PREVIEW_PLAYWRIGHT_TIMEOUT_MS=
LINK_PREVIEW_PLAYWRIGHT_SETTLE_MS=
LINK_PREVIEW_PLAYWRIGHT_SCROLL_PX=

# Исходящий HTTP(S) CONNECT-прокси только для запросов к Gemini (или используй HTTPS_PROXY).
# Нужно, если сервер в регионе вроде RU/CN, где generativelanguage.googleapis.com недоступен:
# VPS в ЕС/US с tinyproxy или туннель. Пример: http://proxy.example.net:3128 или http://user:pass@host:8080
GEMINI_HTTP_PROXY=

# S3 (жильё, документы, фото чеков раздела «Чеки»)
AWS_REGION=ru-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=

# WEB
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=
